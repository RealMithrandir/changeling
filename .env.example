# LLM model for string mutations (optional — omit for deterministic-only mode)
# CHANGELING_LLM_MODEL=gemini/gemini-1.5-flash

# Grimoire config path (default: config/grimoire.toml)
# CHANGELING_GRIMOIRE_PATH=config/grimoire.toml

# Database path (default: changeling.db)
# CHANGELING_DB_PATH=changeling.db

# Bind address
# CHANGELING_HOST=127.0.0.1
# CHANGELING_PORT=8000
